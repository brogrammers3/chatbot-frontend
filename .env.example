# Credenciales de Supabase.
# Copia este archivo a `.env` y reemplaza con los valores reales de tu proyecto
# (Supabase Dashboard → Project Settings → API).
#
# Las variables NEXT_PUBLIC_* se exponen al navegador; la "anon key" es pública
# por diseño, así que no es un secreto. NO pongas aquí la "service_role" key.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
